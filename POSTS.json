      "name": "GetAllPostNoAuth",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "\r",
              "let jsonData = pm.response.json();\r",
              "\r",
              "pm.test(\"The posts are more than one\", function () {\r",
              "    pm.expect(jsonData).to.be.an(\"array\");\r",
              "    pm.expect(jsonData.length).to.be.above(0);\r",
              "    console.log(\" Posts Count:\", jsonData.length);\r",
              "});\r",
              "pm.test(\"Verify if the data has title\", function () {\r",
              "    pm.expect(pm.response.text()).to.include(\"title\");\r",
              "});\r",
              "pm.test(\"Verify if the data has body\", function () {\r",
              "    pm.expect(pm.response.text()).to.include(\"body\");\r",
              "});\r",
              "pm.test(\"Response time is less than 500ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(500);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
